rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.uid == 'b6BsG4T4z5ZfhSsybus6pcakEdB2' ||
        request.auth.token.email == 'divakarkumarmob@gmail.com' || 
        request.auth.token.email == 'shashikumarmob@gmail.com' ||
        request.auth.token.email == 'admin@neet.com'
      );
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }
    match /notifications {
      allow read, write: if isSignedIn();
    }

    match /neet_notifications/{notificationId} {
      allow read, write: if true;
    }
    match /neet_notifications {
      allow read, write: if true;
    }

    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /tests {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /otps/{otpId} {
        allow read, write: if true;
    }
    
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    match /chapterActivity/{activityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Simplified users collection rule
    match /users {
      allow read: if isAdmin();
    }

    // Chat data
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isAdmin() || chatId == request.auth.uid || resource.data.get('participants', []).hasAny([request.auth.uid]));
      allow create: if isSignedIn() && (request.resource.data.get('participants', []).hasAny([request.auth.uid]));
      allow update: if isSignedIn() && (isAdmin() || resource.data.get('participants', []).hasAny([request.auth.uid]));
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isAdmin() || isOwner(chatId) || (get(/databases/$(database)/documents/chats/$(chatId)).data.get('participants', []).hasAny([request.auth.uid]));
      }
    }

    match /chats {
      allow read: if isAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}

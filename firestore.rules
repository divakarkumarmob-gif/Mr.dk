rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /notifications {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Public or shared data
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
    
    match /chapterActivity/{activityId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // User-specific data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /analyses/{analysisId} {
        allow read, write: if isOwner(userId);
      }
      
      match /results/{resultId} {
        allow read, write: if isOwner(userId);
      }
      
      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
      
      match /analytics_v2/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Chat data
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
      
      // User-specific chat history
      match /history/{docId} {
        allow read, write: if isOwner(chatId);
      }

      // Shared chat data
      // (Leaving shared chat data more restrictive)
      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) || request.auth.token.email in ['divakarkumarmob@gmail.com', 'shashikumarmob@gmail.com']);
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) || request.auth.token.email in ['divakarkumarmob@gmail.com', 'shashikumarmob@gmail.com']);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
  "entities": {
    "TestResult": {
      "title": "TestResult",
      "description": "User test result data",
      "type": "object",
      "properties": {
        "testName": { "type": "string" },
        "difficulty": { "type": "string" },
        "correct": { "type": "number" },
        "incorrect": { "type": "number" },
        "unattempted": { "type": "number" },
        "total": { "type": "number" },
        "score": { "type": "number" },
        "marks": { "type": "number" },
        "timeTakenSeconds": { "type": "number" },
        "accuracy": { "type": "number" },
        "speed": { "type": "number" },
        "attemptedRate": { "type": "number" },
        "topicAnalysis": { "type": "array" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["testName", "correct", "total", "userId", "timestamp"]
    },
    "ChapterActivity": {
        "title": "ChapterActivity",
        "description": "Tracks active users in a chapter",
        "type": "object",
        "properties": {
            "chapterId": { "type": "string" },
            "totalActive": { "type": "number" }
        },
        "required": ["chapterId", "totalActive"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Test": {
      "title": "Test",
      "description": "Mock test definition",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["testId", "title", "type"]
    },
    "DailyAnalytics": {
      "title": "DailyAnalytics",
      "description": "Daily analytics data",
      "type": "object",
      "properties": {
        "timeSpentSeconds": { "type": "number" }
      },
      "required": ["timeSpentSeconds"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Conversation between user and admin",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["senderId", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notification",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["message", "timestamp"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Student test performance analysis",
      "type": "object",
      "properties": {
        "questions": { "type": "array" },
        "answers": { "type": "object" },
        "analysisContent": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["analysisContent", "timestamp", "userId"]
    },
    "FlashcardMastery": {
      "title": "FlashcardMastery",
      "description": "Tracks mastered flashcards for a user and chapter",
      "type": "object",
      "properties": {
        "masteredQuestionIds": { "type": "array" },
        "userId": { "type": "string" },
        "chapterName": { "type": "string" }
      },
      "required": ["masteredQuestionIds", "userId", "chapterName"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "users/{userId}/settings/subjects": {
      "schema": "User",
      "description": "User subject settings"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    },
    "tests/{testId}": {
      "schema": "Test",
      "description": "Test data"
    },
    "users/{userId}/analytics/{date}": {
      "schema": "DailyAnalytics",
      "description": "Daily time spent data per date"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages"
    },
    "users/{userId}/results/{resultId}": {
      "schema": "TestResult",
      "description": "User test results"
    },
    "users/{userId}/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "User test analyses"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications"
    },
    "chapterActivity/{chapterId}": {
      "schema": "ChapterActivity",
      "description": "Active users count per chapter"
    },
    "queues/{chapterId}/waitingUsers/{userId}": {
      "schema": "User",
      "description": "Users waiting for a battle"
    },
    "users/{userId}/flashcards/{chapterId}": {
      "schema": "FlashcardMastery",
      "description": "User mastered flashcards"
    }
  }
}

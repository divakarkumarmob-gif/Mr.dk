{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Test": {
      "title": "Test",
      "description": "Mock test definition",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["testId", "title", "type"]
    },
    "DailyAnalytics": {
      "title": "DailyAnalytics",
      "description": "Daily analytics data",
      "type": "object",
      "properties": {
        "timeSpentSeconds": { "type": "number" }
      },
      "required": ["timeSpentSeconds"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Conversation between user and admin",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["senderId", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notification",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["message", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "users/{userId}/settings/subjects": {
      "schema": "User",
      "description": "User subject settings"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    },
    "tests/{testId}": {
      "schema": "Test",
      "description": "Test data"
    },
    "users/{userId}/analytics/{date}": {
      "schema": "DailyAnalytics",
      "description": "Daily time spent data per date"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications"
    }
  }
}
